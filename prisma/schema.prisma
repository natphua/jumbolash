datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Room {
  roomCode       String    @id @unique
  gameState      String    @default("LOBBY") // LOBBY, PROMPTING, VOTING, RESULTS
  roundNumber    Int       @default(1)
  totalRounds    Int       @default(3)       
  timerLimit     Int       @default(90)                
  
  roundStartedAt DateTime? 
  activePromptId String?   
  activePrompt   Prompt?   @relation(fields: [activePromptId], references: [id])

  players        Player[]
  responses      Response[]
}

model Player {
  id        String     @id @default(uuid())
  nickname  String
  roomCode  String
  points    Int        @default(0)
  room      Room       @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  responses Response[]

  @@unique([roomCode, nickname])       
}

model Prompt {
  id        String     @id @default(uuid())
  text      String     // The actual question
  used      Boolean    @default(false)
  
  responses Response[]
  rooms     Room[]     // Prisma requires this reverse relation for activePrompt
}

model Response {
  id         String @id @default(uuid())
  text       String @db.VarChar(120) // 120 char limit 
  votes      Int    @default(0)
  
  // Relations
  roomCode   String
  playerId   String
  promptId   String
  
  room       Room   @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  player     Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  prompt     Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  // Double check that a single player can only submit ONE answer per prompt
  @@unique([playerId, promptId])
}