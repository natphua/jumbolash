datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Room {
  roomCode       String    @id @unique
  gameState      String    @default("LOBBY") // LOBBY, PROMPTING, VOTING, RESULTS
  roundNumber    Int       @default(1)
  totalRounds    Int       @default(5)       
  timerLimit     Int       @default(90)                
  
  roundStartedAt DateTime? 
  activePromptId String?   
  activePrompt   Prompt?   @relation(fields: [activePromptId], references: [id])
  usedPromptIds  String[]   @default([])
  activeMatchupIndex Int    @default(0)
  votingStartedAt DateTime?
  revealStartedAt DateTime?

  players        Player[]
  responses      Response[]
  matchups       Matchup[]
  votes          Vote[]
}

model Player {
  id        String     @id @default(uuid())
  nickname  String
  roomCode  String
  points    Int        @default(0)
  room      Room       @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  responses Response[]
  votes     Vote[]

  @@unique([roomCode, nickname])       
}

model Prompt {
  id        String     @id @default(uuid())
  text      String     // The actual question
  used      Boolean    @default(false)
  
  responses Response[]
  rooms     Room[]     // Prisma requires this reverse relation for activePrompt
  matchups  Matchup[]
}

model Response {
  id         String @id @default(uuid())
  text       String @db.VarChar(120) // 120 char limit 
  votes      Int    @default(0)
  
  // Relations
  roomCode   String
  playerId   String
  promptId   String
  
  room       Room   @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  player     Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  prompt     Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  matchupsAsA Matchup[] @relation("ResponseA")
  matchupsAsB Matchup[] @relation("ResponseB")
  voteRecords Vote[]

  // Double check that a single player can only submit ONE answer per prompt
  @@unique([playerId, promptId])
}

model Matchup {
  id          String   @id @default(uuid())
  roomCode    String
  promptId    String
  responseAId String
  responseBId String?
  roundNumber Int
  matchupIndex Int
  status      String   @default("PENDING") // PENDING, ACTIVE, REVEALED, COMPLETE
  createdAt   DateTime @default(now())

  room       Room     @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  prompt     Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  responseA  Response @relation("ResponseA", fields: [responseAId], references: [id], onDelete: Cascade)
  responseB  Response? @relation("ResponseB", fields: [responseBId], references: [id], onDelete: Cascade)
  votes      Vote[]

  @@unique([roomCode, roundNumber, matchupIndex])
}

model Vote {
  id                 String   @id @default(uuid())
  roomCode           String
  matchupId          String
  voterPlayerId      String
  selectedResponseId String
  createdAt          DateTime @default(now())

  room             Room     @relation(fields: [roomCode], references: [roomCode], onDelete: Cascade)
  matchup          Matchup  @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  voterPlayer      Player   @relation(fields: [voterPlayerId], references: [id], onDelete: Cascade)
  selectedResponse Response @relation(fields: [selectedResponseId], references: [id], onDelete: Cascade)

  @@unique([matchupId, voterPlayerId])
}
